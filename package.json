{
  "name": "gitfast",
  "version": "1.3.0",
  "description": "GitHub actions at the speed of a click",
  "main": "electron/main.js",
  "author": "FRANCK SIMONET MOUAHANYE NDENGA",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,yellow \"vite build --watch\" \"node electron/launch-dev.js\"",
    "build": "vite build",
    "dist": "vite build && electron-builder --win --publish always",
    "dist:local": "vite build && electron-builder --win --publish never",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:linux": "vite build && electron-builder --linux",
    "dist:all": "vite build && electron-builder --win --mac --linux",
    "vite:build": "vite build",
    "preview": "vite preview",
    "electron": "electron ."
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chokidar": "^3.6.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.0.10"
  },
  "build": {
    "appId": "com.gitfast.app",
    "productName": "GitFast",
    "copyright": "Copyright © 2026 GitFast",
    "publish": {
      "provider": "github",
      "owner": "ndengafranck",
      "repo": "gitfast"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [],
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "GitFast-Setup-${version}.exe",
      "publisherName": "GitFast Sarl",
      "legalTrademarks": "GitFast is a trademark of GitFast Sarl",
      "fileAssociations": [
        {
          "ext": "gitfast",
          "name": "GitFast Workflow File",
          "description": "GitFast workflow file",
          "icon": "assets/icon.ico"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GitFast",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools",
      "artifactName": "GitFast-${version}.dmg"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Development",
      "artifactName": "GitFast-${version}.AppImage"
    },
    "asar": true
  }
}
